# Copy into /etc/nginx/sites-available/tg-bot and replace the placeholders.
# The application listens on 127.0.0.1:7799; TLS terminates at Nginx.

server {
    listen 443 ssl http2;
    server_name bot.example.com;

    ssl_certificate     /etc/letsencrypt/live/bot.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/bot.example.com/privkey.pem;

    client_max_body_size 64k;
    proxy_read_timeout 120s;
    proxy_send_timeout 120s;

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    # Clean the client-provided XFF chain before enabling ASK_API_TRUST_PROXY=true.
    proxy_set_header X-Forwarded-For $remote_addr;
    proxy_set_header X-Forwarded-Proto $scheme;

    location = /ask {
        proxy_pass http://127.0.0.1:7799;
    }

    location = /v1/ask {
        proxy_pass http://127.0.0.1:7799;
    }

    location = /health {
        proxy_pass http://127.0.0.1:7799;
    }

    location = /readyz {
        proxy_pass http://127.0.0.1:7799;
    }

    location = /version {
        proxy_pass http://127.0.0.1:7799;
    }

    location = /capabilities {
        proxy_pass http://127.0.0.1:7799;
    }

    location / {
        return 404;
    }
}
