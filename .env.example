# Telegram
BOT_TOKEN=replace_with_telegram_bot_token
ALLOWED_CHAT=123456789

# DeepSeek
DEEPSEEK_KEY_0=replace_with_deepseek_key
DEEPSEEK_KEY_1=
DEEPSEEK_VERIFY_KEY_0=
DEEPSEEK_VERIFY_KEY_1=

# Search APIs
BRAVE_KEY=replace_with_brave_search_key
TAVILY_KEY_0=
TAVILY_KEY_1=
SERPER_KEY_0=
SERPER_KEY_1=
SERPER_KEY_2=

# Optional OpenHuman memory RPC
OPENHUMAN_RPC_TOKEN=

# Optional CalDAV calendar tool
ICAL_URL=https://caldav.icloud.com
ICAL_USER=
ICAL_PASS=

# Runtime storage and HTTP API
TG_BOT_DATA_DIR=/var/lib/morning-report
# Daily report: China + global + AI/technology; generated at 13:00 Asia/Shanghai.
DAILY_REPORT_CATEGORIES=china,global,ai_tech
DAILY_REPORT_ITEMS_PER_CATEGORY=4
DAILY_REPORT_COOLDOWN_DAYS=14
DAILY_REPORT_TIMEZONE=Asia/Shanghai
DAILY_REPORT_STATE_FILE=/var/lib/morning-report/daily_report_state.json
ASK_API_HOST=127.0.0.1
ASK_API_PORT=7799
# Leave empty to generate/store a 0600 token under TG_BOT_DATA_DIR.
ASK_API_TOKEN=
ASK_API_MAX_BODY_BYTES=65536
ASK_API_MAX_QUERY_CHARS=4000
ASK_API_RATE_LIMIT=30
ASK_API_RATE_WINDOW_SECONDS=60
# Only enable when a trusted reverse proxy sets X-Forwarded-For.
ASK_API_TRUST_PROXY=false
